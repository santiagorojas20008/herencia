class Tienda:

    def __init__(self, nombre):
        self.nombre = nombre
        self.inventario = []
        self.total_ventas = 0

    def agregar_producto(self, producto):
        self.inventario.append(producto)

    def eliminar_producto(self, producto):
        if producto in self.inventario:
            self.inventario.remove(producto)

    def registrar_venta(self, monto):
        self.total_ventas += monto

    def mostrar_informacion(self):
        print(f"Tienda: {self.nombre}")
        print(f"Inventario: {self.inventario}")
        print(f"Total de ventas: ${self.total_ventas:.2f}")


class TiendaRopa(Tienda):

    def __init__(self, nombre):
        super().__init__(nombre)

    def mostrar_informacion(self):
        super().mostrar_informacion()
        print("Tipo de tienda: Ropa")


class TiendaElectronica(Tienda):

    def __init__(self, nombre):
        super().__init__(nombre)

    def mostrar_informacion(self):
        super().mostrar_informacion()
        print("Tipo de tienda: Electrónica")


# Ejemplo de uso:

if __name__ == "__main__":

    ropa = TiendaRopa("Moda Joven")
    ropa.agregar_producto("Camisa")
    ropa.agregar_producto("Pantalón")
    ropa.eliminar_producto("Camisa")
    ropa.registrar_venta(35000)
    ropa.mostrar_informacion()

    print()  # Línea en blanco para separar

    electronica = TiendaElectronica("Tech Store")
    electronica.agregar_producto("Laptop")
    electronica.agregar_producto("Celular")
    electronica.registrar_venta(250000)
    electronica.mostrar_informacion()
