class Instrumento:

    def __init__(self, nombre, material):
        self.nombre = nombre
        self.material = material

    def tipo_sonido(self):
        return "Produce un sonido musical."

    def imprimir_detalles(self):
        print(f"Nombre: {self.nombre}")
        print(f"Material: {self.material}")
        print(f"Tipo de sonido: {self.tipo_sonido()}")


class Guitarra(Instrumento):

    def __init__(self, material, cuerdas):
        super().__init__("Guitarra", material)
        self.cuerdas = cuerdas

    def tocar_notas(self):
        return "Do - Re - Mi - Fa - Sol"

    def imprimir_detalles(self):
        super().imprimir_detalles()
        print(f"Cuerdas: {self.cuerdas}")
        print(f"Notas: {self.tocar_notas()}")


class Piano(Instrumento):

    def __init__(self, material, teclas):
        super().__init__("Piano", material)
        self.teclas = teclas

    def tocar_notas(self):
        return "Mi - Fa - Sol - La - Si"

    def imprimir_detalles(self):
        super().imprimir_detalles()
        print(f"Teclas: {self.teclas}")
        print(f"Notas: {self.tocar_notas()}")


# Ejemplo de uso:

if __name__ == "__main__":

    guitarra = Guitarra("Madera", 6)
    guitarra.imprimir_detalles()

    print()  # Línea en blanco para separar

    piano = Piano("Madera", 88)
    piano.imprimir_detalles()
